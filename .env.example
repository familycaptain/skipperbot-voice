# =============================================================================
# skipperbot-voice — companion service config (THIN CLIENT)
# =============================================================================
# Copy to .env and fill in. This service is a satellite: it does audio + wake
# word + realtime streaming locally and delegates the brain/tools to the
# platform over the network. It needs NO database connection, NO OpenAI key,
# and NO platform code — the platform mints the ephemeral OpenAI Realtime token
# and runs all tools. Required values: the platform URL AND a service token
# (the platform enforces auth) — both below.

# ----- Platform API (required) -----
# Where the Skipper platform is reachable. The voice service calls:
#   POST /api/voice/session, WS /ws/voice/{id}, POST /api/voice/end,
#   GET  /api/config/picovoice
SKIPPER_API_BASE=http://localhost:8000
# SKIPPER_API_TIMEOUT=15
# Service token — REQUIRED. The platform enforces auth unconditionally, so
# /api/voice/* calls without this are rejected (401). Issue it on the platform
# host with `python scripts/service_token.py create voice` (in Docker:
# `docker compose exec agent python scripts/service_token.py create voice`) and
# paste it here. Sent as `Authorization: Bearer` (and `?token=` on the websocket).
SKIPPERBOT_TOKEN=

# ----- Wake word -----
# openWakeWord (default) runs locally and needs no key. Only set this if you
# switch to the Porcupine backend; otherwise the platform can also serve it via
# GET /api/config/picovoice.
# PICOVOICE_API_KEY=

# ----- openWakeWord -----
# We install onnxruntime (not tflite-runtime), so run the ONNX framework.
# The Docker image sets this already; uncomment to override outside Docker.
# VOICE_OPENWAKEWORD_INFERENCE_FRAMEWORK=onnx
# VOICE_OPENWAKEWORD_LABEL=          # blank → auto-select wake_words/Hey_Skipper*.onnx
# VOICE_OPENWAKEWORD_THRESHOLD=0.90

# ----- Audio devices (per-OS; see docs) -----
# AUDIO_INPUT_DEVICE=
# AUDIO_OUTPUT_DEVICE=

# ----- Output volume -----
# Some USB speakers (e.g. the EMEET conference speakerphone) reset their
# hardware mixer to the LOWEST level on USB re-enumeration — e.g. each time the
# Docker container restarts (issue #1). Pin a known output level (percent,
# 0-100) so the speaker stays audible. Applied via ALSA (amixer). Test/apply it
# by hand with ./set_volume.sh; leave blank to not touch the mixer.
# VOICE_OUTPUT_VOLUME=80
# Optional: target a specific ALSA card / mixer control if auto-detect is wrong.
# Run `./set_volume.sh --list` to see the names.
# VOICE_OUTPUT_CARD=
# VOICE_OUTPUT_MIXER=

# ----- Mic suppression during playback -----
# Default false: the reference EMEET speakerphone does hardware echo
# cancellation, so full-duplex barge-in works without muting the mic. Set true
# only for hardware with no AEC (you'll lose barge-in while Skipper talks).
# VOICE_SUPPRESS_MIC_DURING_PLAYBACK=false
