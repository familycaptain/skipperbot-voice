# =============================================================================
# skipperbot-voice — companion service config (THIN CLIENT)
# =============================================================================
# Copy to .env and fill in. This service is a satellite: it does audio + wake
# word + realtime streaming locally and delegates the brain/tools to the
# platform over the network. It needs NO database connection, NO OpenAI key,
# and NO platform code — the platform mints the ephemeral OpenAI Realtime token
# and runs all tools. The only required value is the platform URL below.

# ----- Platform API (required) -----
# Where the Skipper platform is reachable. The voice service calls:
#   POST /api/voice/session, WS /ws/voice/{id}, POST /api/voice/end,
#   GET  /api/config/picovoice
SKIPPER_API_BASE=http://localhost:8000
# SKIPPER_API_TIMEOUT=15

# ----- Wake word -----
# openWakeWord (default) runs locally and needs no key. Only set this if you
# switch to the Porcupine backend; otherwise the platform can also serve it via
# GET /api/config/picovoice.
# PICOVOICE_API_KEY=

# ----- openWakeWord -----
# We install onnxruntime (not tflite-runtime), so run the ONNX framework.
# The Docker image sets this already; uncomment to override outside Docker.
# VOICE_OPENWAKEWORD_INFERENCE_FRAMEWORK=onnx
# VOICE_OPENWAKEWORD_LABEL=          # blank → auto-select wake_words/Hey_Skipper*.onnx
# VOICE_OPENWAKEWORD_THRESHOLD=0.90

# ----- Audio devices (per-OS; see docs) -----
# AUDIO_INPUT_DEVICE=
# AUDIO_OUTPUT_DEVICE=
