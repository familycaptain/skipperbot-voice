# =============================================================================
# skipperbot-voice — companion service config
# =============================================================================
# Copy to .env and fill in. This service runs as its own process and shares
# the platform's Postgres database; it is not managed by the platform loader.

# ----- Platform database (same DSN the platform uses) -----
SKIPPERBOT_DB_DSN=

# ----- Platform REST API (preferred integration path: POST /api/chat) -----
SKIPPER_API_BASE=http://localhost:8000

# ----- Wake word / voice -----
PICOVOICE_API_KEY=
# OpenAI Realtime / voice (when the realtime path is used)
OPENAI_VOICE_API_KEY=
# REALTIME_MODEL=
# REALTIME_VOICE=

# ----- Audio devices (per-OS; see docs) -----
# AUDIO_INPUT_DEVICE=
# AUDIO_OUTPUT_DEVICE=
